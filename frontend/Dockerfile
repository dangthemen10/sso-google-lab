# ─────────────────────────────────────────────
# Stage 1 — Install dependencies
# ─────────────────────────────────────────────
FROM node:20-alpine AS deps

WORKDIR /app

# Copy package manifests first to leverage Docker layer cache
COPY package.json package-lock.json* ./

# Install production + dev deps (needed for build).
# Uses npm install (instead of npm ci) because no package-lock.json exists yet.
# Once you commit a package-lock.json you can switch back to: RUN npm ci
RUN npm install

# ─────────────────────────────────────────────
# Stage 2 — Build (Next.js standalone output)
# ─────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY . .

ENV NEXT_TELEMETRY_DISABLED=1

# BE_INTERNAL_URL must be known at BUILD time because next.config.mjs rewrites
# are evaluated during `next build`, not at runtime.
# It is declared as an ARG so docker-compose can pass it in via build.args.
ARG BE_INTERNAL_URL=http://localhost:8080
ENV BE_INTERNAL_URL=$BE_INTERNAL_URL

# Ensure public/ exists so the runner COPY step never fails.
RUN mkdir -p /app/public
RUN npm run build

# ─────────────────────────────────────────────
# Stage 3 — Runtime (minimal standalone image)
# ─────────────────────────────────────────────
FROM node:20-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Non-root user for security
RUN addgroup -S nextjs && adduser -S nextjs -G nextjs

# next build --output standalone copies the minimal server into .next/standalone.
# Public assets and static chunks must be copied alongside it.
# mkdir ensures the public dir exists even if the project has no static assets.
COPY --from=builder --chown=nextjs:nextjs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nextjs /app/.next/static    ./.next/static
COPY --from=builder --chown=nextjs:nextjs /app/public          ./public

USER nextjs

EXPOSE 3000

# server.js is generated by Next.js standalone output
CMD ["node", "server.js"]
