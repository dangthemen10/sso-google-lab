# Copy file này thành .env và điền credentials thật vào.
# File .env KHÔNG được commit vào git.

GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret-here

MICROSOFT_CLIENT_ID=your-azure-app-client-id-here
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret-here

# Keycloak — local mock IdP (không cần đăng ký Google/Microsoft).
# Lấy secret tại: Keycloak Admin UI (http://localhost:8180)
#   → Realm "sso-lab" → Clients → sso-lab-client → Credentials tab
KEYCLOAK_CLIENT_SECRET=your-keycloak-client-secret-here

# Redis — chỉ cần thiết khi chạy local (không dùng Docker Compose).
# Docker Compose tự inject REDIS_HOST=redis qua environment.
# REDIS_HOST=localhost
# REDIS_PORT=6379
